---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "关于我的个人介绍",
	title: "关于",
};
---

<PageLayout meta={meta}>
	<div class="space-y-6">
		<h1 class="title">关于我</h1>
		<div
			class="prose prose-sm prose-cactus prose-headings:font-semibold prose-headings:text-accent-2"
		>
			<p>我是 Muzych，欢迎来到我的个人博客。</p>

			<p>
				这个网站使用了莫兰迪色系的配色方案，旨在创造一个平静、优雅的阅读环境。莫兰迪色系以其低饱和度、柔和的灰调色彩而闻名，能够营造出宁静而不失品味的视觉体验。
			</p>

			<h2>我的兴趣</h2>
			<ul>
				<li>编程与技术探索</li>
				<li>阅读与写作</li>
				<li>音乐欣赏</li>
			</ul>

			<blockquote>
				<p>却道天凉好个秋</p>
			</blockquote>

			<p>感谢您访问我的网站，希望您能在这里找到有价值的内容。</p>
		</div>
	</div>
</PageLayout>
