---
import type { PaginationLink } from "@/types";

interface Props {
	nextUrl?: PaginationLink;
	prevUrl?: PaginationLink;
	currentPage?: number;
	totalPages?: number;
}

const { nextUrl, prevUrl, currentPage, totalPages } = Astro.props;

// 调试信息
console.log(`Paginator组件 - 当前页: ${currentPage}, 总页数: ${totalPages}`);
console.log(`上一页链接: ${prevUrl?.url}, 下一页链接: ${nextUrl?.url}`);
---

<nav class="flex items-center justify-between gap-x-4">
	<div>
		{
			prevUrl && (
				<a
					class="inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 dark:hover:bg-gray-700"
					href={prevUrl.url}
				>
					{prevUrl.srLabel && <span class="sr-only">{prevUrl.srLabel}</span>}
					{prevUrl.text ? prevUrl.text : "上一页"}
				</a>
			)
		}
	</div>

	<div>
		{
			nextUrl && (
				<a
					class="inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 dark:hover:bg-gray-700"
					href={nextUrl.url}
				>
					{nextUrl.srLabel && <span class="sr-only">{nextUrl.srLabel}</span>}
					{nextUrl.text ? nextUrl.text : "下一页"}
				</a>
			)
		}
	</div>
</nav>
