---
const today = new Date();
// import { Icon } from "astro-icon";
---

<footer class="md:flex md:justify-between md:items-center md:align-center font-overpass-mono w-full md:h-full mt-12" >
  <div class="text-[12px] text-justify items-center flex justify-center">
    <b>&copy; {today.getFullYear()} Muzych. All rights reserved.</b>
  </div>
  <div class="flex justify-center gap-3 m-2 sm:m-0">
    <a href="https://twitter.com/1Haxk4541" target="_blank">
      <span class="sr-only">Follow me on X</span>
      <div class="i-line-md:twitter-x w-24px h-24px"></div>
    </a>
    <a href="https://github.com/Muzych" target="_blank">
      <span class="sr-only">Go to Muzych's GitHub repo</span>
      <div class="i-line-md:github-loop w-24px h-24px"></div>
    </a>
    <a href="https://t.me/Muzy_ch" target="_blank">
      <span class="sr-only">Chat with me on Telegram</span>
      <div class="i-line-md:telegram w-24px h-24px"></div>
    </a>
    <a id="rss-link" href="" target="_blank">
      <span class="sr-only">Subscribe to RSS Feed</span>
      <div class="i-line-md:rss w-24px h-24px"></div>
    </a>
  </div>
  <slot />
</footer>
<script src="../scripts/rss.js"></script>