---
import { ViewTransitions } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html class="bg-[rgb(255,255,255)] dark:bg-[rgb(5,5,5)]" lang="en">
    <head>
        <ViewTransitions />
    </head>
    <body
    class="flex flex-col flex-wrap justify-between md:pt-4 md:pr-8 md:pb-4 md:pl-8 p-4 max-w-full min-h-screen dark:bg-[rgb(5,5,5)] dark:text-[rgb(255,255,255)]"
    >
    <Header />
    <slot/>
    <Footer />
</body>
</html>


<script src="../scripts/lightbox.js"></script>
